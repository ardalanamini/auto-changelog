{
  "lsp": {
    "eslint": {
      "settings": {
        "experimental": {
          "useFlatConfig": false,
        },
      },
    },
  },
  "languages": {
    "JavaScript": {
      "formatter": [],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "formatter": [],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "formatter": [],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.vscode",
    "**/.idea",
    "**/dist",
    "**/coverage",
    "**/.cache",
    "**/.cursor",
    "**/node_modules",
    "**/*.tsbuildinfo",
  ],
}
